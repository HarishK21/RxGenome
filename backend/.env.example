# RxGenome Backend Environment Variables

# Database (SQLite by default, or PostgreSQL connection string)
DATABASE_URL=sqlite:///./rxgenome.db

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_STRONG_MODEL=gemini-2.5-pro-preview-06-05

# CORS
CORS_ORIGINS=http://localhost:3000

# Paths (usually auto-detected, override if needed)
# UPLOAD_DIR=./uploads
# ML_ARTIFACT_DIR=../ml/artifacts
# PGX_RULES_PATH=../data/pgx_rules.json
# DEMO_DATA_DIR=../data/demo
